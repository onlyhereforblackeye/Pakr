<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0000">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">
        
        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wana DecryptOr 2.0"
            android:textColor="#FF0000"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />
        
        <!-- Ransom Note -->
        <TextView
            android:id="@+id/ransomNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="YOUR FILES HAVE BEEN ENCRYPTED!"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"
            android:background="#1a0a0a"
            android:padding="20dp"
            android:layout_marginBottom="20dp" />
        
        <!-- Decryption Input -->
        <EditText
            android:id="@+id/decryptInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter decryption key"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#2a1a1a"
            android:padding="10dp"
            android:layout_marginBottom="10dp" />
        
        <!-- Decrypt Button -->
        <Button
            android:id="@+id/decryptBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="DECRYPT"
            android:background="#FF0000"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />
        
        <!-- BTC Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 Send BTC to: bc1q69tmqhm44j7pfclykn3wxq43g9cmagh6f0cf95"
            android:textColor="#00FF00"
            android:textSize="14sp"
            android:background="#1a1a00"
            android:padding="10dp"
            android:layout_marginBottom="20dp" />
        
        <!-- ===== CHAT SECTION ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- 💬 NEGOTIATION CHAT ---"
            android:textColor="#FF8800"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#333300"
            android:padding="10dp"
            android:layout_marginBottom="10dp" />
        
        <!-- Chat Display -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#1a1a1a"
            android:layout_marginBottom="10dp">
            
            <TextView
                android:id="@+id/chatDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:padding="10dp"
                android:text="💬 Chat started...\n" />
        </ScrollView>
        
        <!-- Chat Input & Send -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <EditText
                android:id="@+id/chatInput"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Type message..."
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:background="#2a2a2a"
                android:padding="10dp" />
            
            <Button
                android:id="@+id/sendBtn"
                android:layout_width="80dp"
                android:layout_height="50dp"
                android:text="SEND"
                android:background="#008800"
                android:textColor="#FFFFFF" />
        </LinearLayout>
        <!-- ===== END CHAT SECTION ===== -->
        
    </LinearLayout>
</ScrollView>
